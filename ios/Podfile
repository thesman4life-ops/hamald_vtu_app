platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = '1'

# Fix for CocoaPods 1.15+ TypeError: no implicit conversion of nil into Hash
project 'Runner',
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :release

def flutter_install_all_ios_pods(ios_application_path = nil)
  ios_application_path ||= File.dirname(File.realpath(__FILE__))
  # Path to the Generated.xcconfig
  config_path = File.join(ios_application_path, 'Flutter', 'Generated.xcconfig')

  if !File.exist?(config_path)
    # If the file doesn't exist yet, we can't determine the Flutter SDK path.
    # However, CocoaPods needs at least one dependency to avoid the "no dependencies" error.
    # We use a dummy dependency if necessary, but 'Flutter' is better if it can be found.
    pod 'Flutter', :head
    return
  end

  flutter_framework_dir = nil
  File.foreach(config_path) do |line|
    if match = line.match(/\s*FLUTTER_FRAMEWORK_DIR\s*=\s*(.*)\s*/)
      flutter_framework_dir = match[1].strip
    end
  end

  if flutter_framework_dir && !flutter_framework_dir.empty?
    pod 'Flutter', :path => File.join(flutter_framework_dir, 'Flutter.podspec')
  else
    pod 'Flutter', :head
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end
